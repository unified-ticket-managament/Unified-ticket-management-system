# .env.example


APP_NAME=
APP_ENV=
DEBUG=

API_V1_PREFIX=

DATABASE_URL=

LOG_LEVEL=

# Object storage. STORAGE_BACKEND=supabase (default) or "s3" for any
# S3-compatible host (MinIO locally, Cloudflare R2/AWS S3 in prod).
STORAGE_BACKEND=supabase
STORAGE_BUCKET=communication-attachments
STORAGE_URL_EXPIRY_SECONDS=3600

# Required when STORAGE_BACKEND=supabase. Service role key is
# server-only — never expose it to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required when STORAGE_BACKEND=s3.
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=False