VITE_API_BASE_URL=http://localhost:8000

# RBAC service — sole issuer of login/refresh/me. If running both
# services locally at once, RBAC can't also bind :8000 (Ticketing's
# default) — start it with `uvicorn app.main:app --reload --port 8001`
# and point this at that port instead.
VITE_RBAC_API_BASE_URL=http://localhost:8000/api/v1
