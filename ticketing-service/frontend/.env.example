VITE_API_BASE_URL=http://localhost:8001

# RBAC service — sole issuer of login/refresh/me. Running both services
# locally at once, Ticketing's backend can't also bind :8000 (RBAC's
# default) — start Ticketing with `uvicorn app.main:app --reload --port 8001`
# and point VITE_API_BASE_URL above at that port instead.
VITE_RBAC_API_BASE_URL=http://localhost:8000/api/v1
