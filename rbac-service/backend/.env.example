# Application
APP_NAME=Enterprise RBAC Platform
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://rbac_user:rbac_password@localhost:5432/rbac_db

# JWT — shared with the Ticketing service (ticketing-service/backend/.env's
# JWT_SECRET_KEY). RBAC is the sole token issuer; Ticketing only verifies,
# using the identical secret value.
JWT_SECRET_KEY=change-this-to-a-secure-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — must also include the Ticketing frontend's origin, since it calls
# this service's /auth/* endpoints directly (cross-origin) for the unified
# login flow, e.g.: http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:3000

# Security
SECURE_COOKIES=false

# Logging
LOG_LEVEL=INFO
