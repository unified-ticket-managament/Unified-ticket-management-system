NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Ticketing's own routes (tickets/agents/inbox/etc.) are served by the
# same unified backend as NEXT_PUBLIC_API_URL above, just mounted
# unprefixed instead of under /api/v1 — see unified-backend/app/main.py.
NEXT_PUBLIC_TICKETING_API_URL=http://localhost:8000

# Ticketing's frontend (separate app/origin) — linked from the sidebar's
# "Ticket Workspace" item, opened in a new tab. Sessions aren't shared
# across origins, so users land on that app's own /login if not already
# signed in there.
NEXT_PUBLIC_TICKETING_FRONTEND_URL=http://localhost:5173
